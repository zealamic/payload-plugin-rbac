{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "composite": false,
    "incremental": false,
    "noEmit": false
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx"],
  "exclude": ["./dev", "./dist", "**/*.test.ts", "**/*.spec.ts"]
}

{
  "name": "@zealamic/payload-plugin-rbac",
  "version": "1.0.0",
  "description": "A plugin for Payload CMS to manage authentication and authorization",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zealamic/payload-plugin-rbac.git"
  },
  "bugs": {
    "url": "https://github.com/zealamic/payload-plugin-rbac/issues"
  },
  "homepage": "https://github.com/zealamic/payload-plugin-rbac#readme",
  "keywords": [
    "payload",
    "plugin",
    "rbac",
    "authentication",
    "authorization",
    "payloadcms",
    "payload-plugin",
    "payload-rbac",
    "payload-plugin-rbac",
    "zealamic"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/exports/client.d.ts",
      "import": "./dist/exports/client.js",
      "default": "./dist/exports/client.js"
    },
    "./rsc": {
      "types": "./dist/exports/rsc.d.ts",
      "import": "./dist/exports/rsc.js",
      "default": "./dist/exports/rsc.js"
    },
    "./utils": {
      "types": "./dist/lib/utils/index.d.ts",
      "import": "./dist/lib/utils/index.js",
      "default": "./dist/lib/utils/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/general-types.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "copy:styles": "node -e \"require('fs').cpSync('src/styles', 'dist/styles', {recursive:true})\"",
    "copy:general-types": "node -e \"require('fs').cpSync('src/general-types.d.ts', 'dist/general-types.d.ts', {recursive:true})\"",
    "build": "yarn copyfiles && yarn build:types && yarn build:swc && yarn copy:styles && yarn copy:general-types",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --project tsconfig.build.json",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts TSX_TSCONFIG_PATH=./dev/tsconfig.json payload generate:importmap",
    "dev:generate-types": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts TSX_TSCONFIG_PATH=./dev/tsconfig.json payload generate:types",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts TSX_TSCONFIG_PATH=./dev/tsconfig.json payload",
    "generate:importmap": "yarn dev:generate-importmap",
    "generate:types": "yarn dev:generate-types",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepublishOnly": "yarn clean && yarn build",
    "test": "yarn test:int && yarn test:e2e",
    "test:e2e": "playwright test",
    "test:int": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@payloadcms/db-mongodb": "3.85.0",
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/db-sqlite": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/translations": "^3.84.1",
    "@payloadcms/ui": "3.85.0",
    "@playwright/test": "1.60.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "^1.15.40",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "copyfiles": "2.4.1",
    "cross-env": "^10.1.0",
    "graphql": "^16.8.1",
    "mongodb-memory-server": "11.2.0",
    "next": "16.2.7",
    "open": "^11.0.0",
    "payload": "3.85.0",
    "qs-esm": "8.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rimraf": "6.1.3",
    "sharp": "0.34.5",
    "sort-package-json": "^4.0.0",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "payload": "^3.84.1"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "registry": "https://registry.npmjs.org/",
  "dependencies": {}
}
